# Python virtual environment
.venv/

# ROOT compilation artifacts
*.so
*.d
*.pcm
*_ACLiC_dict_rdict.pcm
*.dSYM/

# Analysis output (large files — regenerated by running the analysis)
Analysis/Output/

# Python bytecode
__pycache__/

# Raw test-beam data (~18 GB; fetched externally — see README "Quick Start")
Data/

# Legacy lineage: keep the old code (legacy/*.C, *.py) but not its large binaries
legacy/Output_old/
legacy/*.root
legacy/*.pdf

# macOS
.DS_Store

# Local Claude Code agent state (machine-specific)
.claude/

# reduced ntuples copied from Argon (per-config, multi-GB) — data, not source
reduced/

# Multi-year dataset payloads: keep the dir skeleton + config + figures, ignore
# the raw / reduced / analysis-output data (regenerated; large).
datasets/*/raw/*
datasets/*/reduced/*
datasets/*/output/*
!datasets/**/.gitkeep
