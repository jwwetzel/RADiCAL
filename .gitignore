# Python virtual environment
.venv/

# ROOT compilation artifacts
*.so
*.d
*.pcm
*_ACLiC_dict_rdict.pcm
*.dSYM/

# Analysis output (large files — regenerated by running the analysis)
Analysis/Output/

# Python bytecode
__pycache__/

# macOS
.DS_Store

# Local Claude Code agent state (machine-specific)
.claude/

# ----------------------------------------------------------------------------
# Data payloads (large; fetched from CERNBox or regenerated by the pipeline).
# Keep the dir skeleton + configs + metadata; ignore the raw/reduced/output blobs.
# data/<year>/{raw,reduced,output} are the only large, regenerated trees.
# ----------------------------------------------------------------------------
data/*/raw/*
data/*/reduced/*
data/*/output/*
!data/**/.gitkeep

# Transient analysis/report build output (regenerated)
output/
Analysis/Output/

# Archived legacy lineage: keep the old code, not its large binaries
archive/**/Output_old/
archive/**/*.root
archive/**/*.pdf

# LaTeX build artifacts — with a deliberate exception: committed gate-result logs
# (papers/scripts/*/*.log evidence files) are tracked via `git add -f` and must
# never be deleted or regenerated silently; this pattern only keeps NEW LaTeX
# .log noise out. See ANALYSIS_GUIDE.md "gate discipline".
papers/**/*.log

# workspace audit A10: generator build artifact (canonical copy: papers/timing/figs/) + third-party source assets pending rights decision + macOS noise
papers/scripts/apparatus_composite/apparatus_composite.pdf
papers/timing/NIM_A_Figures/
.DS_Store
