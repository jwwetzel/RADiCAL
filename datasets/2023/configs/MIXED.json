    "mcp1": [0,0,7],
    "mcp2": [0,1,7],
    "wc": { "xr": [1,1,1], "xl": [1,1,2], "yd": [1,1,3], "yu": [1,1,5], "scale_mm_per_ns_frac": [7, 36] },
