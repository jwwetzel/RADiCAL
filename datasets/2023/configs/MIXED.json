  "geometry": {
    "X0_mm": 5.4, "RM_mm": 13.7, "depth_X0": 25, "transverse_mm": 14,
    "n_lyso": 29, "lyso_mm": 1.5, "n_w": 28, "w_mm": 2.5,
    "module_center_wc_mm": [6.6, 4.7]
