// TEMPLATE build config — copy to datasets/<year>/configs/<BUILD>.json and edit.
// This is the ONLY file you write to add new data (different channel mapping,
// new year, new module). MiniJson allows // comments. See radcore/README.md.
{
  "year": 2024,                      // campaign year -> datasets/<year>/
  "build": "MYBUILD",                // -> datasets/<year>/reduced/MYBUILD/<E>GeV.root
  "description": "one line: what module/fill this is",

  "digitizer": {                     // DRS4 geometry (defaults shown)
    "model": "CAEN DT5742",
    "boards": 2, "groups_per_board": 2, "chans_per_group": 9, "samples": 1024, "sample_ns": 0.2,
    "hg_sat_mV": 950   // HG positive clip [mV]. 2023 ~820 (clip onset; modal 836) from the DC-offset window; measure YOUR run's positive rail from the hg_peak pile-up
  },

  "channel_map": {
    // hardware coords [drs, grp, ch]. List the 8 readouts in CANONICAL ORDER:
    // NW-D, NE-D, SE-D, SW-D, NW-U, NE-U, SE-U, SW-U.  hg = timing (DRS0 side),
    // lg = energy (DRS1 side), mcp_ref = 1 or 2.  Change these if the wiring
    // differs from 2023.
    "ends": [
      { "corner": "NW", "end": "D", "hg": [0,0,1], "lg": [1,0,1], "mcp_ref": 1 },
      { "corner": "NE", "end": "D", "hg": [0,0,2], "lg": [1,0,2], "mcp_ref": 1 },
      { "corner": "SE", "end": "D", "hg": [0,0,3], "lg": [1,0,3], "mcp_ref": 1 },
      { "corner": "SW", "end": "D", "hg": [0,0,0], "lg": [1,0,0], "mcp_ref": 1 },
      { "corner": "NW", "end": "U", "hg": [0,0,5], "lg": [1,0,5], "mcp_ref": 1 },
      { "corner": "NE", "end": "U", "hg": [0,0,4], "lg": [1,0,4], "mcp_ref": 1 },
      { "corner": "SE", "end": "U", "hg": [0,0,6], "lg": [1,0,6], "mcp_ref": 1 },
      { "corner": "SW", "end": "U", "hg": [0,1,0], "lg": [1,0,7], "mcp_ref": 2 }
    ],
    "mcp1": [0,0,7],
    "mcp2": [0,1,7],
    "wc": { "xr": [1,1,1], "xl": [1,1,2], "yd": [1,1,3], "yu": [1,1,5], "scale_mm_per_ns_frac": [7, 36] },
    "pbglass": [ [0,1,1], [0,1,2], [0,1,3], [0,1,4] ]
  },

  "capillaries": [                   // per corner: material + role (timing|energy)
    { "corner": "NW", "material": "DSB1", "role": "timing" },
    { "corner": "NE", "material": "DSB1", "role": "timing" },
    { "corner": "SE", "material": "DSB1", "role": "timing" },
    { "corner": "SW", "material": "DSB1", "role": "timing" }
  ],

  "geometry": {
    "X0_mm": 5.4, "RM_mm": 13.7, "depth_X0": 25, "transverse_mm": 14,
    "n_lyso": 29, "lyso_mm": 1.5, "n_w": 28, "w_mm": 2.5,
    "module_center_wc_mm": [0.0, 0.0]
  },

  "mcp_ref_jitter_ps": 73,

  // EITHER inline (local reduction):
  "runs": { "150": ["RUN0000_150_GeV.root"] }
  // OR point at a manifest CSV for full HPC reduction:
  // "runs_manifest": "Analysis/hpc/manifest_MYBUILD.csv"
}
